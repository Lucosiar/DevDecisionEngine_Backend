PORT=3000

# Optional single origin for frontend
FRONTEND_URL=http://localhost:3001

# Optional multiple origins separated by comma
# Example: https://app.example.com,https://staging.example.com
CORS_ORIGINS=

# OpenAI API key to enable AI analysis in POST /analyze
OPENAI_API_KEY=

# Optional model override (default in code: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Optional default repository analyzed when request does not include repositoryUrl
ANALYZE_REPOSITORY_URL=https://github.com/Lucosiar/DevDecisionEngine_Demo.git

# Optional repository catalog for GET /analyze/repositories (comma-separated URLs)
# Example: https://github.com/Lucosiar/DevDecisionEngine_Demo.git,https://github.com/Lucosiar/DevDecisionEngine_Backend.git
ANALYZE_REPOSITORIES=
